# Madar — environment variables
# Copy to .env.local for local dev. Never commit real secrets.

# ────────────────────────────────────────────────────────────
# Phase 1 slice — POS Sell Screen with mock data
# No backend variables required yet. Real entries land in later phases.
# ────────────────────────────────────────────────────────────

# Public — exposed to the browser (NEXT_PUBLIC_*)
NEXT_PUBLIC_APP_NAME="Madar"
NEXT_PUBLIC_DEFAULT_CURRENCY="EGP"

# Server-only

# Database (Phase 1.4, role split ADR 0004)
# Three roles, three URLs:
#   * DATABASE_URL        → `madar_app`   — non-superuser, tenant realm at
#                           runtime. The tenant_isolation RLS policy applies
#                           to it; this is what makes isolation enforce.
#   * ADMIN_DATABASE_URL  → `madar_admin` — non-superuser, super-admin realm
#                           (adminPrisma). Its admin_full_access policy is the
#                           ONLY cross-tenant read path — there is no session
#                           variable bypass.
#   * DIRECT_DATABASE_URL → `madar`       — superuser table owner, used by
#                           `prisma migrate` for DDL and by tests'
#                           `migrate reset`.
# All URLs become PgBouncer-aware in prod; statement-pooling mode is forbidden
# (see packages/db/README.md).
DATABASE_URL="postgresql://madar_app:madar_app@localhost:5432/madar?schema=public"
ADMIN_DATABASE_URL="postgresql://madar_admin:madar_admin@localhost:5432/madar?schema=public"
DIRECT_DATABASE_URL="postgresql://madar:madar@localhost:5432/madar?schema=public"

# API (Phase 1.5a) — tenant auth backend
# Generate JWT_TENANT_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_TENANT_SECRET="change-me-32-bytes-base64-encoded-secret-value"
JWT_TENANT_ACCESS_TTL="15m"
JWT_TENANT_REFRESH_TTL="30d"

# API (Phase 1.6a) — admin (platform) auth realm
# JWT_ADMIN_SECRET MUST be distinct from JWT_TENANT_SECRET — that's the realm boundary.
JWT_ADMIN_SECRET="change-me-distinct-from-tenant-secret-32-bytes-base64"
JWT_ADMIN_ACCESS_TTL="8h"
JWT_ADMIN_REFRESH_TTL="8h"
JWT_ADMIN_MFA_PENDING_TTL="5m"

# API (Phase 1.5b + 1.5c) — tenant email-bound flows + MFA
JWT_TENANT_MFA_PENDING_TTL="5m"
PASSWORD_RESET_TTL_HOURS="1"
EMAIL_VERIFICATION_TTL_HOURS="24"

REDIS_URL="redis://localhost:6379"
API_PORT="4000"
# Comma-separated origins. Tenant on :3000, admin on :3001.
API_CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Payment-proof receipt storage (1.11a). LocalDiskStorage writes here.
# Real MinIO/S3 wiring lands with 1.11d.
STORAGE_ROOT="./var/storage"

# Storage backend selection (1.11d). "local" uses STORAGE_ROOT; "s3" uses MinIO/S3.
STORAGE_PROVIDER="local"
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="madar-receipts"
S3_ACCESS_KEY="madar"
S3_SECRET_KEY="madar-dev-only"
S3_FORCE_PATH_STYLE="true"

# Postgres backup container (opt-in via `docker compose --profile backup up -d`).
# Targets the same MinIO by default — point at real AWS/B2/R2 in production.
# See docs/operations/backups.md.
BACKUP_S3_BUCKET="madar-backups"
BACKUP_S3_ACCESS_KEY="madar"
BACKUP_S3_SECRET_KEY="madar-dev-only"
BACKUP_S3_REGION="us-east-1"
BACKUP_CRON="0 2 * * *"
BACKUP_RETAIN_DAYS="30"

# Browser-visible — points at the API
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Virus scanning (ClamAV). Default "noop" for local dev; set "clamav" in prod.
VIRUS_SCANNER="noop"
CLAMAV_HOST="localhost"
CLAMAV_PORT="3310"

# Email (Phase 1.15)
# Local dev defaults to disk-writer (no network); prod sets EMAIL_PROVIDER=resend.
EMAIL_PROVIDER="disk"
# RESEND_API_KEY="re_..."           # required when EMAIL_PROVIDER=resend
EMAIL_FROM="Madar <hello@madar.dev>"
EMAIL_LOG_DIR="./var/sent-emails"
TENANT_WEB_ORIGIN="http://localhost:3000"

# Signup gate — set "false" to block public registration.
SIGNUP_ENABLED="true"

# Platform bank account encryption (A7). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production; optional for local dev (operations that need it will throw at runtime).
# PLATFORM_BANK_ENCRYPTION_KEY=""

# Admin app origin (A8). Used in invite email links.
ADMIN_WEB_ORIGIN="http://localhost:3001"

# Observability — Sentry (Phase 1.15). All optional locally; init is a no-op when empty.
# SENTRY_DSN_API="https://...@sentry.io/..."
# SENTRY_ENVIRONMENT="development"
# NEXT_PUBLIC_SENTRY_DSN_TENANT=""
# NEXT_PUBLIC_SENTRY_DSN_ADMIN=""
