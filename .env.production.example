# Madar — production environment template.
# Copy to .env.production, fill in every value, and never commit the result.

# ─── Hostnames (used by Caddy + CORS) ─────────────────────────────────
# Three subdomains pointing at the same VPS via DNS A records.
TENANT_HOST="shop.example.com"
ADMIN_HOST="admin.example.com"
API_HOST="api.example.com"
CADDY_ACME_EMAIL="you@example.com"
# Optional: apex / "naked" domain (e.g. "example.com") that 301-redirects to
# TENANT_HOST. Add an A record for the apex first, then uncomment and set.
# ROOT_HOST="example.com"

# ─── Database ──────────────────────────────────────────────────────────
POSTGRES_USER="madar"
POSTGRES_PASSWORD="CHANGE_ME_use_a_long_random_string"
# Runtime roles (non-superuser). The migrations create both with placeholder
# passwords — rotate them after the first migration run (docs/deployment.md §5b):
#   ALTER ROLE madar_app   PASSWORD '...';
#   ALTER ROLE madar_admin PASSWORD '...';
# madar_app   → tenant realm (tenant_isolation RLS applies)
# madar_admin → super-admin realm (admin_full_access RLS; the ONLY cross-tenant path)
MADAR_APP_PASSWORD="CHANGE_ME_strong_password_for_app_role"
MADAR_ADMIN_PASSWORD="CHANGE_ME_strong_password_for_admin_role"
# DATABASE_URL / ADMIN_DATABASE_URL are rebuilt from these inside the compose file.
# DIRECT_DATABASE_URL (superuser) is also set in compose for Prisma CLI migrations.
# The API container connects via the bridge network as `postgres:5432`.

# ─── Admin IP allowlist (optional hardening) ───────────────────────────
# Comma-separated IPs and/or IPv4 CIDRs allowed to reach /v1/admin/*
# (including the admin login). Leave empty to disable.
# ADMIN_IP_ALLOWLIST="203.0.113.7,10.8.0.0/24"

# ─── JWT secrets (32+ chars each, both unique) ─────────────────────────
# Tenant-realm + admin-realm tokens are signed with separate secrets so a
# leak of one realm can't impersonate the other.
JWT_TENANT_SECRET="CHANGE_ME_64_random_chars_for_tenant_jwt_signing"
JWT_ADMIN_SECRET="CHANGE_ME_64_random_chars_for_admin_jwt_signing"
JWT_TENANT_ACCESS_TTL="15m"
JWT_TENANT_REFRESH_TTL="30d"
JWT_TENANT_MFA_PENDING_TTL="5m"
JWT_ADMIN_ACCESS_TTL="8h"
JWT_ADMIN_REFRESH_TTL="8h"
JWT_ADMIN_MFA_PENDING_TTL="5m"

# ─── MinIO / S3-compatible storage ─────────────────────────────────────
# Used for: payment proof receipts, product images, tenant logos,
# supplier documents. Always-on prod backups also default to MinIO unless
# pointed at real S3 (see BACKUP_* below).
MINIO_ROOT_USER="madar"
MINIO_ROOT_PASSWORD="CHANGE_ME_long_random_string"
STORAGE_PROVIDER="s3"
S3_REGION="us-east-1"
S3_BUCKET="madar-receipts"
S3_ACCESS_KEY="madar"
S3_SECRET_KEY="CHANGE_ME_long_random_string"
S3_FORCE_PATH_STYLE="true"

# ─── Email — Resend (real send) ────────────────────────────────────────
EMAIL_PROVIDER="resend"
RESEND_API_KEY="re_CHANGE_ME"
EMAIL_FROM="Madar <hello@shop.example.com>"

# Tenant web origin — used in password-reset + verify-email + invite links.
# Must match the Caddy TENANT_HOST + https://.
TENANT_WEB_ORIGIN="https://shop.example.com"
ADMIN_WEB_ORIGIN="https://admin.example.com"

# ─── Browser-visible API URL ───────────────────────────────────────────
NEXT_PUBLIC_API_URL="https://api.example.com"

# ─── Cookie scoping for cross-subdomain auth ──────────────────────────
# Set to your *registrable* domain prefixed with a dot, so the refresh
# cookie set by api.example.com is also visible to admin.example.com and
# shop.example.com (the Next.js SSR layouts read it to gate protected
# pages). Without this, MFA succeeds but the browser bounces back to /login.
# Leave as "localhost" for local dev (host-only cookie).
COOKIE_DOMAIN=".example.com"

# ─── CORS allowlist for the API ────────────────────────────────────────
API_CORS_ORIGIN="https://shop.example.com,https://admin.example.com"

# ─── Backups (off-site, ideally to real S3/B2) ─────────────────────────
# For real S3 / Backblaze B2 / Cloudflare R2, point BACKUP_S3_ENDPOINT at
# their endpoint instead of the in-stack MinIO.
BACKUP_S3_BUCKET="madar-backups"
BACKUP_S3_ACCESS_KEY="madar"
BACKUP_S3_SECRET_KEY="CHANGE_ME_long_random_string"
BACKUP_S3_REGION="us-east-1"
BACKUP_CRON="0 2 * * *"
BACKUP_RETAIN_DAYS="30"

# ─── Sentry (optional but recommended) ─────────────────────────────────
SENTRY_DSN_API=""
SENTRY_ENVIRONMENT="production"
NEXT_PUBLIC_SENTRY_DSN_TENANT=""
NEXT_PUBLIC_SENTRY_DSN_ADMIN=""

# ─── Virus scanning (ClamAV) ───────────────────────────────────────────
# "clamav" in production (real scanning), "noop" for local dev only.
VIRUS_SCANNER="clamav"
CLAMAV_HOST="clamav"
CLAMAV_PORT="3310"

# ─── Signup gate ───────────────────────────────────────────────────────
# Set to "false" to block public registration (returns 403). Toggle on when
# ready to accept new tenants. Existing tenants can still log in.
SIGNUP_ENABLED="false"

# ─── Misc behaviour ────────────────────────────────────────────────────
PASSWORD_RESET_TTL_HOURS="1"
EMAIL_VERIFICATION_TTL_HOURS="24"
REFUND_MANAGER_THRESHOLD_CENTS="5000"
ADMIN_CRON_PATTERN="0 8 * * *"
