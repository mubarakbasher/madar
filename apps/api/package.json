    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.4",
    "@sentry/node": "^10.53.1",
    "argon2": "^0.41.1",
    "bullmq": "^5.76.10",
