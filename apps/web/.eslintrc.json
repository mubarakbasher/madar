{
  "extends": "next/core-web-vitals",
  "plugins": ["i18next"],
  "rules": {
    "i18next/no-literal-string": [
      "warn",
      {
        "markupOnly": true,
        "ignoreAttribute": [
          "className",
          "style",
          "type",
          "name",
          "id",
          "htmlFor",
          "role",
          "href",
          "src",
          "key",
          "autoComplete",
          "inputMode",
          "data-testid",
          "data-theme",
          "data-state"
        ],
        "ignore": [
          "^[^a-zA-Z]*$",
          "^[A-Z_]+$",
          "^\\s*$"
        ],
        "ignoreCallee": [
          "require",
          "console.*",
          "useTranslations",
          "useQuery",
          "useMutation",
          "useForm"
        ]
      }
    ],
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "@madar/db",
            "message": "The tenant web app must not import @madar/db. Frontend code talks to the API over HTTP; data-layer code lives in apps/api."
          },
          {
            "name": "@prisma/client",
            "message": "The tenant web app must not import @prisma/client. Frontend code talks to the API over HTTP; data-layer code lives in apps/api."
          }
        ],
        "patterns": [
          {
            "group": ["@madar/db/*"],
            "message": "The tenant web app must not import @madar/db. Frontend code talks to the API over HTTP."
          }
        ]
      }
    ]
  }
}
