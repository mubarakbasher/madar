{
  "name": "madar",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@madar/web",
    "dev:admin": "turbo run dev --filter=@madar/admin",
    "dev:api": "turbo run dev --filter=@madar/api",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@madar/api",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "i18n:check": "pnpm --filter=@madar/web run i18n:check",
    "db:generate": "pnpm --filter=@madar/db run db:generate",
    "db:migrate": "pnpm --filter=@madar/db run db:migrate",
    "db:migrate:deploy": "pnpm --filter=@madar/db run db:migrate:deploy",
    "db:reset": "pnpm --filter=@madar/db run db:reset",
    "db:studio": "pnpm --filter=@madar/db run db:studio",
    "db:seed": "pnpm --filter=@madar/db run db:seed",
    "test:rls": "pnpm --filter=@madar/db run test:rls",
    "test:api": "pnpm --filter=@madar/api run test",
    "test:realm": "pnpm --filter=@madar/api run test:realm"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
